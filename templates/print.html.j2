<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>{{ data.restaurant.name }} 有機野菜マップ</title>
<style>
  @page { size: A4; margin: 0; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { width: 210mm; height: 297mm; }
  body {
    font-family: "Noto Sans CJK JP", sans-serif;
    color: #2B2A22;
    background: #F6F1E2;
    background-image:
      radial-gradient(ellipse at 8% 6%, rgba(63,92,58,0.05), transparent 40%),
      radial-gradient(ellipse at 95% 90%, rgba(193,101,47,0.06), transparent 45%);
    position: relative;
  }
  .sheet { width:210mm; height:297mm; padding:8mm 10mm 6mm 10mm; display:flex; flex-direction:column; position:relative; }
  .frame { position:absolute; inset:4.5mm; border:1px solid #C7BB9C; border-radius:3mm; pointer-events:none; }

  header { display:flex; align-items:flex-start; justify-content:space-between; padding-bottom:2.2mm; border-bottom:1.1px solid #C1652F; margin-bottom:2.4mm; }
  .header-left { flex:1; padding-right:5mm; }
  .eyebrow { font-size:7.6pt; letter-spacing:0.22em; color:#7A6F4E; font-weight:500; margin-bottom:1.2mm; }
  h1 { font-family:"Noto Serif CJK JP",serif; font-weight:700; font-size:15pt; line-height:1.3; color:#33502E; }
  .lede { margin-top:1.6mm; font-size:6.6pt; line-height:1.5; color:#47432F; max-width:120mm; }
  .badge-store { flex-shrink:0; width:24mm; text-align:center; }
  .badge-store .stamp { width:19mm; height:19mm; margin:0 auto; border-radius:50%; border:1.5px solid #C1652F; display:flex; align-items:center; justify-content:center; position:relative; }
  .badge-store .stamp::before { content:""; position:absolute; inset:3px; border:0.6px solid #C1652F; border-radius:50%; opacity:.55; }
  .badge-store .stamp span { font-family:"Noto Serif CJK JP",serif; font-size:9pt; font-weight:700; color:#C1652F; }

  .map-title-row { display:flex; align-items:baseline; justify-content:space-between; margin-bottom:1mm; }
  .map-title { font-family:"Noto Serif CJK JP",serif; font-size:10pt; font-weight:700; color:#33502E; }
  .map-note { font-size:5.8pt; color:#8A7F5E; }
  .map-box { border:1px solid #C7BB9C; border-radius:2.5mm; background:#EFF3EC; padding:1mm; }

  .lower { display:flex; gap:4mm; flex:1; min-height:0; margin-top:2.6mm; }
  .col-list { flex:1.15; }
  .col-prod { flex:1; }

  .col-title { font-family:"Noto Serif CJK JP",serif; font-size:9pt; font-weight:700; color:#33502E; background:#E7E9D9; border-radius:1.2mm; padding:0.9mm 2mm; margin-bottom:1.4mm; display:inline-block; }
  .col-title.prod-t { background:#F1E6D3; color:#C1652F; }
  .honor-note { font-size:6pt; font-weight:500; opacity:0.75; margin-left:1.2mm; }

  .list-subgrid { display:flex; gap:3.5mm; }
  .list-subcol { flex:1; min-width:0; }

  .area-tag { font-size:6.3pt; font-weight:700; color:#9C4A1E; margin:0 0 0.7mm 0; }
  .area-tag.oita { color:#33502E; }
  .area-tag.bungo { color:#9C7A20; }

  .s-item { padding:0.7mm 0; border-bottom:0.6px dashed #C7BB9C; }
  .s-item:last-child { border-bottom:none; }
  .s-item.highlight { background:#FCEFE0; border-radius:1.5mm; padding:0.9mm 1.3mm; margin-bottom:0.5mm; border-bottom:none; }
  .s-row { display:flex; align-items:flex-start; gap:1.1mm; }
  .pin { flex-shrink:0; width:3.4mm; height:3.4mm; border-radius:50%; background:#33502E; color:#F6F1E2; font-size:5.2pt; font-weight:700; display:flex; align-items:center; justify-content:center; margin-top:0.2mm; }
  .pin.usuki { background:#9C4A1E; }
  .pin.bungo { background:#9C7A20; }
  .s-info { flex:1; min-width:0; }
  .s-name-row { display:flex; align-items:center; gap:0.9mm; flex-wrap:wrap; }
  .s-name { font-size:6.6pt; font-weight:700; color:#2B2A22; line-height:1.2; }
  .lbadge { font-size:4.6pt; font-weight:700; padding:0.1mm 1mm; border-radius:2.5mm; text-decoration:none; line-height:1.35; white-space:nowrap; color:#fff; }
  .lbadge.map { background:#33502E; }
  .lbadge.hp { background:#C1652F; }
  .s-addr { font-size:5.4pt; color:#7A7160; margin-top:0.1mm; }

  .p-item { padding:0.8mm 0; border-bottom:0.6px dashed #C7BB9C; }
  .p-item:last-child { border-bottom:none; }
  .p-name { font-size:6.8pt; font-weight:700; color:#33502E; text-decoration:none; border-bottom:1px dotted #33502E; }
  .p-name.nolink { color:#2B2A22; border-bottom:none; }
  .p-stores { font-size:5.4pt; color:#8A7F5E; margin-top:0.4mm; }
  .p-stores b { color:#9C4A1E; font-weight:700; }
  .p-pending { font-size:6pt; color:#7A7160; margin-top:1mm; padding-top:1mm; border-top:1px solid #C7BB9C; }

  .footer { margin-top:2.2mm; display:flex; gap:4mm; align-items:stretch; }
  .market-block { flex:1; }
  .market-title { font-family:"Noto Serif CJK JP",serif; font-size:8.6pt; font-weight:700; color:#F6F1E2; background:#33502E; padding:1mm 3mm; border-radius:2mm 2mm 0 0; }
  .market-cards { display:flex; gap:3mm; background:#EFE6CF; border-radius:0 0 2mm 2mm; padding:1.8mm 3mm; }
  .market-card { flex:1; }
  .market-name-row { display:flex; align-items:center; gap:1.1mm; margin-bottom:0.4mm; flex-wrap:wrap; }
  .market-name { font-size:6.9pt; font-weight:700; color:#C1652F; }
  .market-meta { font-size:5.7pt; color:#2B2A22; line-height:1.45; }

  .bottom-note { margin-top:1.6mm; text-align:center; font-size:5.5pt; color:#8A7F5E; }

  svg text { font-family:"Noto Sans CJK JP","Noto Serif CJK JP",serif; }
</style>
</head>
<body>
<div class="sheet">
  <div class="frame"></div>

  <header>
    <div class="header-left">
      <div class="eyebrow">{{ data.header.eyebrow }}</div>
      <h1>{{ data.header.title }}</h1>
      <p class="lede">{{ data.header.lede }}</p>
    </div>
    <div class="badge-store"><div class="stamp"><span>{{ data.restaurant.name }}</span></div></div>
  </header>

  <div class="map-title-row">
    <div class="map-title">{{ data.map.title }}</div>
    <div class="map-note">{{ data.map.note }}</div>
  </div>
  <div class="map-box">
{% set svg_extra_attrs = 'height="257"' %}
{% include "map_svg.j2" %}
  </div>

  <div class="lower">
    <div class="col-list">
      <div class="col-title">お野菜が買えるお店<span class="honor-note">(敬称略)</span></div>
      <div class="list-subgrid">
        <div class="list-subcol">
          {% for area in areas if area.id in ("usuki", "bungo") %}
          <div class="area-tag {{ 'bungo' if area.id == 'bungo' else '' }}"{% if area.id == "bungo" %} style="margin-top:1.4mm;"{% endif %}>{{ area.label }}</div>
          {% for store in stores_by_area[area.id] %}
          <div class="s-item{{ ' highlight' if store.highlight }}">
            <div class="s-row"><div class="pin {{ area.pin_class }}">{{ store.number }}</div>
              <div class="s-info">
                <div class="s-name-row"><div class="s-name">{{ store.name }}</div>
                  <a class="lbadge map" href="{{ store.map_url }}">MAP</a>
                  {% if store.hp_url %}<a class="lbadge hp" href="{{ store.hp_url }}">HP</a>{% endif %}
                </div>
                <div class="s-addr">{{ store.address }}</div>
              </div></div>
          </div>
          {% endfor %}
          {% endfor %}
          <div class="other-note" style="margin-top:1.6mm; font-size:5.8pt; color:#7A7160; line-height:1.6;">
            {{ data.producers_extra_note }}<br>
            <b style="color:#33502E;">{{ data.producers_pending.label }}</b>：
            <a href="{{ data.producers_pending.url }}" style="color:#9C4A1E;">{{ data.producers_pending.name }}</a>
          </div>
        </div>

        <div class="list-subcol">
          {% for area in areas if area.id == "oita" %}
          <div class="area-tag oita">{{ area.label }}</div>
          {% for store in stores_by_area[area.id] %}
          <div class="s-item">
            <div class="s-row"><div class="pin">{{ store.number }}</div>
              <div class="s-info">
                <div class="s-name-row"><div class="s-name">{{ store.name }}</div>
                  <a class="lbadge map" href="{{ store.map_url }}">MAP</a>
                  {% if store.hp_url %}<a class="lbadge hp" href="{{ store.hp_url }}">HP</a>{% endif %}
                </div>
                <div class="s-addr">{{ store.address }}</div>
              </div></div>
          </div>
          {% endfor %}
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="col-prod">
      <div class="col-title prod-t">生産者さん一覧<span class="honor-note">(敬称略・順不同)</span></div>
      {% for p in data.producers %}
      <div class="p-item">
        {% if p.url %}<a class="p-name" href="{{ p.url }}">{{ p.name }}</a>{% else %}<span class="p-name nolink">{{ p.name }}</span>{% endif %}
        <div class="p-stores">取扱店 <b>{{ p.store_numbers_str }}</b>{% if p.extra_note %}{{ p.extra_note }}{% endif %}</div>
      </div>
      {% endfor %}
      <div class="p-pending">
        <b style="color:#9C4A1E;">{{ data.producers_pending.label }}</b>：
        <a class="p-name" href="{{ data.producers_pending.url }}">{{ data.producers_pending.name }}</a>
      </div>
    </div>
  </div>

  <div class="footer">
    <div class="market-block">
      <div class="market-title">定期開催・有機野菜のマルシェ</div>
      <div class="market-cards">
        {% for m in data.markets %}
        <div class="market-card">
          <div class="market-name-row">
            <div class="market-name">{{ m.name }}</div>
            <a class="lbadge map" href="{{ m.map_url }}">MAP</a>
            <a class="lbadge hp" href="{{ m.hp_url }}">HP</a>
          </div>
          <div class="market-meta">{{ m.meta }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="bottom-note">※ {{ data.bottom_note }}</div>
</div>
</body>
</html>
