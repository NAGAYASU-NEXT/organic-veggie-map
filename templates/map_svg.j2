{# Shared map SVG. The municipality shapes / decorations are hand-illustrated
   and kept static; only the numbered pins, the market pins, and the
   restaurant marker are driven by data.json so new stores show up
   automatically once you add them there. #}
<svg viewBox="{{ data.map.viewBox }}" width="100%" {{ svg_extra_attrs|safe }} preserveAspectRatio="xMidYMid meet">
  <defs>
    <linearGradient id="skyGrad3" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#F6F1E2"/>
      <stop offset="0.55" stop-color="#EAF0E6"/>
      <stop offset="1" stop-color="#DCEDEA"/>
    </linearGradient>
  </defs>
  <rect x="0" y="0" width="700" height="460" fill="url(#skyGrad3)"/>

  <circle cx="655" cy="40" r="17" fill="#F6D27A"/>
  <g stroke="#F6D27A" stroke-width="2.6" stroke-linecap="round">
    <line x1="655" y1="14" x2="655" y2="6"/>
    <line x1="681" y1="40" x2="689" y2="40"/>
    <line x1="673" y1="22" x2="679" y2="16"/>
    <line x1="673" y1="58" x2="679" y2="64"/>
  </g>

  <path d="M 610 0 L 700 0 L 700 460 L 640 460 C 660 420 620 390 640 350 C 660 310 630 280 650 240
           C 670 200 630 160 650 120 C 665 90 640 55 610 20 Z" fill="#DCEDEA" opacity="0.7"/>
  <g fill="none" stroke="#9FC4C6" stroke-width="2" stroke-linecap="round" opacity="0.7">
    <path d="M640 60 q9 7 18 0 q9 -7 18 0"/>
    <path d="M660 130 q9 7 18 0 q9 -7 18 0"/>
    <path d="M655 210 q9 7 18 0 q9 -7 18 0"/>
    <path d="M640 300 q9 7 18 0 q9 -7 18 0"/>
    <path d="M620 380 q9 7 18 0 q9 -7 18 0"/>
  </g>

  <path d="M 20 30 C 55 20 100 25 122 50 C 135 68 130 92 112 108
           C 90 122 55 118 35 100 C 18 85 12 55 20 30 Z"
        fill="#DED3EC" stroke="#B7A9CC" stroke-width="1.8" stroke-linejoin="round"/>
  <text x="55" y="72" font-size="11.5" font-weight="700" fill="#5C4A78">由布市</text>

  <path d="M 150 -8 L 250 -8 C 268 8 262 32 240 42 C 215 52 180 48 162 32
           C 148 20 145 5 150 -8 Z"
        fill="#F3CFC7" stroke="#D9A79D" stroke-width="1.8" stroke-linejoin="round"/>
  <text x="172" y="24" font-size="11" font-weight="700" fill="#9C4A3E">別府市</text>
  <g fill="none" stroke="#B9615A" stroke-width="1.6" stroke-linecap="round" opacity="0.8">
    <path d="M220 -2 q-4 6 0 11 q4 5 0 11"/>
  </g>

  <path d="M 165 55 C 210 40 280 35 330 45 C 380 35 440 45 470 70
           C 495 90 500 115 480 135 C 500 155 500 180 478 200
           C 470 220 445 235 415 240 C 380 245 350 240 330 225
           C 300 245 260 245 235 228 C 210 245 175 240 155 220
           C 135 200 130 175 145 150 C 125 130 128 100 148 78
           C 152 68 158 60 165 55 Z"
        fill="#F1E3C6" stroke="#D8C79E" stroke-width="2.2" stroke-linejoin="round"/>
  <text x="230" y="120" font-size="15" font-weight="700" fill="#5C4A22">大分市</text>

  <path d="M 275 300 C 305 288 350 292 375 310 C 392 324 393 348 375 365
           C 352 383 315 385 288 373 C 268 362 258 340 265 320
           C 268 310 270 305 275 300 Z"
        fill="#D2E2C1" stroke="#A9C393" stroke-width="1.8" stroke-linejoin="round"/>
  <text x="270" y="395" font-size="11.5" font-weight="700" fill="#4F6B2E">豊後大野市</text>

  <path d="M 455 195 C 480 182 515 182 540 195 C 558 206 565 222 558 238
           C 552 250 540 258 525 262 C 518 275 505 288 490 300
           C 500 312 500 328 488 340 C 470 355 445 358 425 350
           C 400 342 388 322 393 302 C 380 292 375 275 385 260
           C 395 240 415 228 430 218 C 435 208 445 200 455 195 Z"
        fill="#F3D3A8" stroke="#D9AE72" stroke-width="1.8" stroke-linejoin="round"/>
  <text x="470" y="195" font-size="12.5" font-weight="700" fill="#8C5A1E">臼杵市</text>
  <g transform="translate(500,272)" opacity="0.7" fill="#B98548">
    <ellipse cx="0" cy="10" rx="9" ry="5"/>
    <path d="M-6 10 C -6 -2 6 -2 6 10 Z"/>
    <circle cx="0" cy="-4" r="4"/>
  </g>

  <path d="M 545 250 C 570 240 598 245 613 262 C 624 278 620 298 602 310
           C 580 320 555 313 545 296 C 538 280 537 262 545 250 Z"
        fill="#F0C4B9" stroke="#D89C8C" stroke-width="1.8" stroke-linejoin="round"/>
  <text x="548" y="295" font-size="10.5" font-weight="700" fill="#8C4A34">津久見市</text>

  {# --- restaurant marker (data-driven position) --- #}
  <g transform="translate({{ data.restaurant.marker.cx }},{{ data.restaurant.marker.cy }})">
    <path d="M0,-22 C9,-22 16,-15 16,-6 C16,6 0,24 0,24 C0,24 -16,6 -16,-6 C-16,-15 -9,-22 0,-22 Z" fill="#C1652F" stroke="#7A3D18" stroke-width="1.5"/>
    <circle cx="0" cy="-7" r="7.5" fill="#FFF8EC"/>
    <text x="0" y="-3" font-size="8.5" font-weight="700" fill="#C1652F" text-anchor="middle">春</text>
  </g>
  <text x="{{ data.restaurant.marker.cx }}" y="{{ data.restaurant.marker.label_y }}" font-size="11.5" font-weight="700" fill="#7A3D18" text-anchor="middle">{{ data.restaurant.name }}</text>

  {# --- store pins, grouped by area color (data-driven) --- #}
  {% for area in areas %}
  <g font-size="13" font-weight="700" fill="#fff" text-anchor="middle">
    {% for store in stores_by_area[area.id] %}
    <g><circle cx="{{ store.pin.cx }}" cy="{{ store.pin.cy }}" r="13" fill="{{ area.color }}"/><text x="{{ store.pin.cx }}" y="{{ store.pin.cy + 5 }}">{{ store.number }}</text></g>
    {% endfor %}
  </g>
  {% endfor %}

  {# --- market pins (diamond markers, data-driven) --- #}
  <g font-size="8" font-weight="700" fill="#fff" text-anchor="middle">
    {% for market in data.markets %}
    <g><rect x="{{ market.pin.cx - 9 }}" y="{{ market.pin.cy - 9 }}" width="18" height="18" rx="3" fill="#7A8B4A" transform="rotate(45 {{ market.pin.cx }} {{ market.pin.cy }})"/><text x="{{ market.pin.cx }}" y="{{ market.pin.cy + 3 }}">市</text></g>
    {% endfor %}
  </g>
</svg>
